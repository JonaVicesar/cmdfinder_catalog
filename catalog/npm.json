{
  "npm": {
    "program_description": "npm - Node.js package manager",
    "actions": {
      "install-package": {
        "aliases": [
          "install package",
          "add package",
          "install dependency",
          "npm install",
          "get package",
          "add dependency",
          "install npm"
        ],
        "description": "Installs a package as a project dependency",
        "commands": [
          "npm install <package>",
          "npm install <package> --save-dev  # as a development dependency only"
        ]
      },
      "install-global": {
        "aliases": [
          "install globally",
          "global install",
          "npm global",
          "install global package",
          "global npm"
        ],
        "description": "Installs a package available globally on your machine",
        "commands": ["npm install -g <package>"]
      },
      "uninstall-package": {
        "aliases": [
          "uninstall package",
          "remove package",
          "delete package",
          "remove dependency",
          "npm uninstall",
          "uninstall npm"
        ],
        "description": "Removes a package from the project",
        "commands": ["npm uninstall <package>"]
      },
      "update-packages": {
        "aliases": [
          "update packages",
          "upgrade dependencies",
          "npm update",
          "refresh packages",
          "update dependencies"
        ],
        "description": "Updates packages according to the package.json limits",
        "commands": [
          "npm update",
          "npm outdated  # check which ones are outdated before updating"
        ]
      },
      "clear-cache": {
        "aliases": [
          "clear cache",
          "purge cache",
          "clean npm",
          "reset cache",
          "npm cache clean"
        ],
        "description": "Cleans the npm cache (useful when installs are acting weird)",
        "commands": ["npm cache clean --force"]
      },
      "run-script": {
        "aliases": [
          "run script",
          "npm run",
          "execute script",
          "start script",
          "launch script",
          "run npm script"
        ],
        "description": "Runs a script defined in package.json",
        "commands": [
          "npm run <script-name>",
          "npm start  # shortcut if the script is named 'start'"
        ]
      },
      "init-project": {
        "aliases": [
          "init project",
          "create package.json",
          "npm init",
          "new project",
          "start project",
          "initialize npm"
        ],
        "description": "Creates a new package.json",
        "commands": ["npm init -y  # with defaults, no questions asked"]
      },
      "check-vulnerabilities": {
        "aliases": [
          "check vulnerabilities",
          "npm audit",
          "security check",
          "audit packages",
          "check security",
          "vulnerability scan"
        ],
        "description": "Checks for known vulnerabilities in your dependencies",
        "commands": [
          "npm audit",
          "npm audit fix  # attempts to auto-fix what it can"
        ]
      }
    }
  }
}
